#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/backend"

if ! command -v php >/dev/null 2>&1; then
    echo "[ERROR] PHP was not found in PATH."
    exit 1
fi

if [[ ! -f .env ]]; then
    echo "[ERROR] backend/.env does not exist."
    exit 1
fi

if [[ ! -f vendor/autoload.php ]]; then
    echo "[ERROR] Backend PHP dependencies are missing. Run: cd backend && composer install"
    exit 1
fi

if [[ ! -f public/build/manifest.json ]]; then
    echo "[ERROR] Backend assets are missing. Run: cd backend && yarn install --frozen-lockfile && yarn build"
    exit 1
fi

echo "Backend: http://127.0.0.1:8000"
echo "Admin:   http://127.0.0.1:8000/admin"
echo "Press Ctrl+C to stop."
echo

exec php artisan serve --host=127.0.0.1 --port=8000
