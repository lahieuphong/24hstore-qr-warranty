APP_NAME="24hStore Warranty Lookup"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost:8001
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
FORCE_HTTPS=false

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BACKEND_API_URL=http://localhost:8000/api/v1
BACKEND_ADMIN_URL=http://localhost:8000/admin
BACKEND_API_TIMEOUT=8

VITE_APP_NAME="${APP_NAME}"
