#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/frontend"

if ! command -v php >/dev/null 2>&1; then
    echo "[ERROR] PHP was not found in PATH."
    exit 1
fi

if [[ ! -f .env ]]; then
    echo "[ERROR] frontend/.env does not exist."
    exit 1
fi

if [[ ! -f vendor/autoload.php ]]; then
    echo "[ERROR] Frontend PHP dependencies are missing. Run: cd frontend && composer install"
    exit 1
fi

if [[ ! -f public/build/manifest.json ]]; then
    echo "[ERROR] Frontend assets are missing. Run: cd frontend && yarn install --frozen-lockfile && yarn build"
    exit 1
fi

echo "Frontend: http://localhost:8001"
echo "Backend must also be running at http://127.0.0.1:8000"
echo "Press Ctrl+C to stop."
echo

exec php artisan serve --host=127.0.0.1 --port=8001
