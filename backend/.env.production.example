APP_NAME="24hStore QR Warranty Backend"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=https://admin-warranty.example.com
FRONTEND_URL=https://warranty.example.com
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
FORCE_HTTPS=true

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qr_warranty
DB_USERNAME=qr_warranty
DB_PASSWORD=replace_with_a_long_random_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_SITE_NAME="24hStore Administration"
ADMIN_SITE_TAGLINE="Quản trị QR bảo hành"
ADMIN_NAME="Quản trị hệ thống"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_unique_password_at_least_12_chars
