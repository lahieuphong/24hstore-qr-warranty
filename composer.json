{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "24hstore/qr-warranty",
  "type": "project",
  "description": "Ứng dụng quản trị và tra cứu QR bảo hành 24hStore.",
  "keywords": ["laravel", "livewire", "qr", "warranty", "inventory"],
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "barryvdh/laravel-dompdf": "^3.1",
    "endroid/qr-code": "^6.1",
    "laravel/framework": "^12.0",
    "laravel/tinker": "^2.10.1",
    "livewire/livewire": "^4.0",
    "maatwebsite/excel": "^3.1.69",
    "spatie/laravel-permission": "^8.3",
    "technikermathe/blade-lucide-icons": "3.160.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/breeze": "^2.4",
    "laravel/pail": "^1.2.2",
    "laravel/pint": "^1.24",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.6",
    "phpunit/phpunit": "^11.5.50"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup": [
      "composer install",
      "@php artisan key:generate",
      "@php artisan migrate --seed --force",
      "yarn install --frozen-lockfile --non-interactive",
      "yarn build"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "yarn run concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"yarn dev\" --names=server,queue,vite --kill-others"
    ],
    "test": [
      "@php artisan config:clear --ansi",
      "@php artisan test"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
