# Public application settings
APP_NAME="24hStore"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=https://your-service-name.onrender.com
APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN
FORCE_HTTPS=true
APP_MAINTENANCE_DRIVER=file

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=info

# Neon PostgreSQL
DB_CONNECTION=pgsql
DB_URL=
DB_SSLMODE=require

# Render Free runs one web service, so keep state in PostgreSQL
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# Demo email delivery is written to the application logs
MAIL_MAILER=log

# Initial production administrator
ADMIN_SITE_NAME="24hStore Administration"
ADMIN_SITE_TAGLINE="Quản trị QR bảo hành"
ADMIN_NAME="Quản trị hệ thống"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# The seeders are idempotent and create the roles plus the first administrator.
RUN_DATABASE_SEEDER=true
